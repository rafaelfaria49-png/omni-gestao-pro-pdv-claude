# 1) Supabase → Project Settings → Database → Connect → copie as URIs (Transaction vs Direct).
# 2) Senha com caracteres especiais: use a URI já codificada do painel.
#
# Recomendado (Next.js / Prisma em dev e produção): Transaction pooler na porta 6543 para não estourar max_connections.
# O Prisma exige ?pgbouncer=true em modo transação. connection_limit=1 ajuda em serverless/HMR.
#
# DATABASE_URL = pooler transação (6543) — uso geral da aplicação
# DIRECT_URL   = conexão direta (5432) — prisma migrate, db push, introspection
#
# Formato comum (host db.<ref>.supabase.co:6543 — painel "Transaction"):
DATABASE_URL="postgresql://postgres:SENHA@db.<PROJECT_REF>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=15&sslmode=require"
#
# Alternativa regional (pooler compartilhado), se o painel mostrar aws-0-REGION:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:SENHA@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
#
# Conexão direta (migrations / db pull). sslmode + connect_timeout + supavisor em hosts db.* ajudam rede restrita:
DIRECT_URL="postgresql://postgres:SENHA@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require&connect_timeout=30&supavisor=true"
# Opcional: tempo extra (ms) para prismaEnsureConnected() em lib/prisma.ts
# PRISMA_CONNECT_WAIT_MS=35000
