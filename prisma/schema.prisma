// --- Fornecedores + contas a pagar (multi-loja; `storeId` obrigatório em todas as linhas)

/**
 * Fornecedor cadastrado por unidade (não compartilhar entre lojas).
 */
model Fornecedor {
  id               String   @id @default(cuid())
  storeId          String   @default("loja-1") @map("storeId")
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Nome fantasia / exibição.
   */
  name             String   @map("name")
  /**
   * Razão social (opcional, mas suportada pela UI).
   */
  legalName        String   @default("") @map("legalName")
  /**
   * Contato principal (opcional).
   */
  contactName      String   @default("") @map("contactName")
  /**
   * CPF/CNPJ ou identificador fiscal livre.
   */
  document         String   @default("") @map("document")
  email            String   @default("") @map("email")
  phone            String   @default("") @map("phone")
  whatsapp         String   @default("") @map("whatsapp")
  /**
   * Endereço completo (rua/numero/bairro/cidade/uf/cep) como texto livre.
   */
  address          String   @default("") @map("address") @db.Text
  /**
   * Lista livre de itens fornecidos (texto).
   */
  productsProvided String   @default("") @map("productsProvided") @db.Text
  /**
   * Prazo médio (texto, ex.: "5 dias").
   */
  avgLeadTime      String   @default("") @map("avgLeadTime")
  /**
   * Condição de pagamento (texto, ex.: "30/60").
   */
  paymentTerms     String   @default("") @map("paymentTerms")
  notes            String?  @map("notes") @db.Text
  active           Boolean  @default(true) @map("active")
  createdAt        DateTime @default(now()) @map("createdAt")
  updatedAt        DateTime @updatedAt @map("updatedAt")

  contasPagar ContaPagarTitulo[]

  @@index([storeId])
  @@index([name])
  @@map("fornecedores")
}

/**
 * Categorias do Cadastros HUB (multi-entidade) por unidade.
 */
model CategoriaCadastro {
  id        String   @id @default(cuid())
  storeId   String   @default("loja-1") @map("storeId")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name      String   @map("name")
  /**
   * "produto" | "servico" | "equipamento" | "geral"
   */
  type      String   @default("geral") @map("type")
  active    Boolean  @default(true) @map("active")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  @@unique([storeId, type, name], name: "categoria_cadastro_store_type_name")
  @@index([storeId])
  @@index([type])
  @@map("categorias_cadastro")
}

/**
 * Marcas do Cadastros HUB por unidade.
 */
model MarcaCadastro {
  id        String   @id @default(cuid())
  storeId   String   @default("loja-1") @map("storeId")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name      String   @map("name")
  /**
   * Opcional: classificar por tipo (produto/equipamento/geral).
   */
  type      String   @default("") @map("type")
  active    Boolean  @default(true) @map("active")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  @@unique([storeId, type, name], name: "marca_cadastro_store_type_name")
  @@index([storeId])
  @@index([type])
  @@map("marcas_cadastro")
}

/**
 * Título a pagar (fornecedor, boleto, aluguel, etc.) — escopo exclusivo da loja.
 */
model ContaPagarTitulo {
  id              String      @id @default(cuid())
  storeId         String      @default("loja-1") @map("storeId")
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Opcional: vínculo com cadastro de fornecedor da mesma loja.
   */
  fornecedorId    String?     @map("fornecedorId")
  fornecedor      Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  /**
   * Id estável no cliente (localStorage / sync), por unidade.
   */
  localKey        String?     @map("localKey")
  /**
   * Snapshot JSON (parcelas, anexos, histórico de pagamento, etc.).
   */
  payload         Json?       @map("payload") @db.JsonB
  descricao       String      @default("") @map("descricao")
  valor           Float       @default(0) @map("valor")
  vencimento      String      @default("") @map("vencimento")
  status          String      @default("pendente") @map("status")
  /**
   * NF, número de boleto ou referência externa.
   */
  numeroDocumento String      @default("") @map("numeroDocumento")
  createdAt       DateTime    @default(now()) @map("createdAt")
  updatedAt       DateTime    @updatedAt @map("updatedAt")

  @@unique([storeId, localKey])
  @@index([storeId])
  @@index([fornecedorId])
  @@index([status])
  @@map("contas_pagar_titulos")
}

// --- Contas a receber + vendas (servidor; opcional — o painel ainda usa localStorage por padrão)

/**
 * Título a receber no Postgres; relação 1:N com vendas vinculadas.
 */
model ContaReceberTitulo {
  id         String   @id @default(cuid())
  storeId    String   @default("loja-1") @map("storeId")
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Id estável do título no navegador (localStorage) — upsert idempotente por unidade.
   */
  localKey   String?  @map("localKey")
  /**
   * Snapshot JSON do registro completo (parcelas, histórico, etc.).
   */
  payload    Json?    @map("payload") @db.JsonB
  descricao  String   @default("") @map("descricao")
  cliente    String   @default("") @map("cliente")
  valor      Float    @default(0) @map("valor")
  vencimento String   @default("") @map("vencimento")
  status     String   @default("pendente") @map("status")
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  vendas Venda[]

  @@unique([storeId, localKey])
  @@index([storeId])
  @@index([cliente])
  @@map("contas_receber_titulos")
}

/**
 * Carteira / conta financeira do HUB Financeiro (caixa, banco, PIX, dinheiro, etc.).
 * Modelo nativo do OmniGestão — separado do FinancialAccount (Finance Pro page).
 */
model CarteiraFinanceira {
  id           String   @id @default(cuid())
  storeId      String   @default("loja-1") @map("storeId")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  nome         String   @map("nome")
  /**
   * "caixa" | "banco" | "pix" | "dinheiro" | "credito" | "debito" | "investimento"
   */
  tipo         String   @default("caixa") @map("tipo")
  saldoInicial Float    @default(0) @map("saldoInicial")
  saldoAtual   Float    @default(0) @map("saldoAtual")
  ativo        Boolean  @default(true) @map("ativo")
  /**
   * Cor hex p/ UI, ex.: "#22c55e"
   */
  cor          String   @default("#6366f1") @map("cor")
  /**
   * Ícone (nome Lucide), ex.: "wallet", "landmark", etc.
   */
  icone        String   @default("wallet") @map("icone")
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  movimentacoes MovimentacaoFinanceira[]
  conciliacoes  ConciliacaoFinanceira[]

  @@index([storeId])
  @@index([storeId, ativo])
  @@map("carteiras_financeiras")
}

model MovimentacaoFinanceira {
  id           String              @id @default(cuid())
  storeId      String              @default("loja-1") @map("storeId")
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * "entrada" | "saida"
   */
  tipo         String              @default("entrada") @map("tipo")
  /**
   * "os" | "venda" | "manual" | "pagar" | etc
   */
  origem       String              @default("manual") @map("origem")
  /**
   * Id de referência (ContaReceberTitulo/ContaPagarTitulo/Venda/etc.)
   */
  referenciaId String?             @map("referenciaId")
  descricao    String              @default("") @map("descricao")
  valor        Float               @default(0) @map("valor")
  /**
   * Carteira que recebe ou debita esta movimentação (opcional).
   */
  carteiraId   String?             @map("carteiraId")
  carteira     CarteiraFinanceira? @relation(fields: [carteiraId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now()) @map("createdAt")

  @@index([storeId])
  @@index([tipo])
  @@index([origem])
  @@index([referenciaId])
  @@index([carteiraId])
  @@index([createdAt])
  @@map("movimentacoes_financeiras")
}

/**
 * Venda (PDV ou importada) opcionalmente ligada a um título em aberto.
 */
model Venda {
  id                   String              @id @default(cuid())
  storeId              String              @default("loja-1") @map("storeId")
  store                Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Ex.: VDA-2026-0001 — chave de negócio
   */
  pedidoId             String              @unique @map("pedidoId")
  /**
   * Snapshot JSON da venda (formas de pagamento, linhas, etc.) para recuperação fiel.
   */
  payload              Json?               @map("payload") @db.JsonB
  total                Float               @default(0) @map("total")
  at                   DateTime            @default(now()) @map("at")
  clienteNome          String?             @map("clienteNome")
  /**
   * FK opcional para o cliente cadastrado.
   * Nulo em vendas de consumidor final ou vendas antigas sem vínculo.
   * Preservado via SetNull se o cliente for excluído.
   */
  clienteId            String?             @map("clienteId")
  cliente              Cliente?            @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  /**
   * Status do ciclo de vida da venda.
   * concluida | cancelada | parcialmente_devolvida | devolvida
   */
  status               String              @default("concluida") @map("status")
  /** Operador que realizou a venda (extraído de payload.cashierId). */
  operador             String?             @map("operador")
  canceladaEm          DateTime?           @map("canceladaEm")
  canceladaPor         String?             @map("canceladaPor")
  motivoCancelamento   String?             @map("motivoCancelamento")
  contaReceberTituloId String?             @map("contaReceberTituloId")
  contaReceberTitulo   ContaReceberTitulo? @relation(fields: [contaReceberTituloId], references: [id], onDelete: SetNull)
  itens                ItemVenda[]

  @@index([storeId])
  @@index([storeId, status])
  @@index([clienteId])
  @@index([contaReceberTituloId])
  @@map("vendas")
}

model ItemVenda {
  id            String  @id @default(cuid())
  vendaId       String  @map("vendaId")
  venda         Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  inventoryId   String? @map("inventoryId")
  nome          String  @default("") @map("nome")
  quantidade    Int     @default(1) @map("quantidade")
  precoUnitario Float   @default(0) @map("precoUnitario")
  lineTotal     Float   @default(0) @map("lineTotal")

  @@index([vendaId])
  @@map("venda_itens")
}

// ─── PDV Enterprise — Devoluções ─────────────────────────────────────────────

/**
 * Documento de devolução/troca PDV.
 * - `localId` = id gerado no localStorage (DEV-YYYY-NNNN), usado para idempotência.
 * - `tipo`: "vale_credito" | "somente_estoque" | "troca"
 * - `sessaoId`: opcional, vincula à sessão de caixa ativa no momento.
 * - `vendaId`: opcional, venda original. Null se venda só existe no localStorage.
 */
model DevolucaoVenda {
  id             String      @id @default(cuid())
  storeId        String      @map("storeId")
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /** Chave de negócio local (DEV-2026-0001). Unique por loja. */
  localId        String      @map("localId")
  vendaLocalId   String      @default("") @map("vendaLocalId")
  sessaoId       String?     @map("sessaoId")
  sessao         SessaoCaixa? @relation(fields: [sessaoId], references: [id], onDelete: SetNull)
  /** "vale_credito" | "somente_estoque" | "troca" */
  tipo           String      @map("tipo")
  valorTotal     Float       @default(0) @map("valorTotal")
  creditoEmitido Float       @default(0) @map("creditoEmitido")
  clienteNome    String      @default("") @map("clienteNome")
  clienteDoc     String      @default("") @map("clienteDoc")
  operador       String      @default("") @map("operador")
  motivo         String      @default("") @map("motivo")
  observacao     String      @default("") @map("observacao")
  at             DateTime    @default(now()) @map("at")
  /** Snapshot com linhas e contexto. */
  payload        Json?       @map("payload") @db.JsonB
  itens          ItemDevolucaoVenda[]

  @@unique([storeId, localId])
  @@index([storeId, at])
  @@index([storeId, vendaLocalId])
  @@map("devolucoes_venda")
}

model ItemDevolucaoVenda {
  id            String         @id @default(cuid())
  devolucaoId   String         @map("devolucaoId")
  devolucao     DevolucaoVenda @relation(fields: [devolucaoId], references: [id], onDelete: Cascade)
  inventoryId   String?        @map("inventoryId")
  nome          String         @default("") @map("nome")
  quantidade    Int            @default(1) @map("quantidade")
  valorUnitario Float          @default(0) @map("valorUnitario")
  valorTotal    Float          @default(0) @map("valorTotal")

  @@index([devolucaoId])
  @@map("itens_devolucao_venda")
}

/**
 * Usuários internos do sistema (operadores e administradores).
 */
model User {
  id              String           @id @default(cuid())
  name            String           @default("") @map("name")
  /**
   * PIN numérico/curto usado para autorização rápida no PDV.
   */
  pin             String           @unique @map("pin")
  /**
   * "ADMIN" | "CAIXA" (mantido string para compatibilidade simples).
   */
  role            String           @default("CAIXA") @map("role")
  credits         Int              @default(0)
  usages          Usage[]
  creditPurchases CreditPurchase[]
  createdAt       DateTime         @default(now()) @map("createdAt")
  updatedAt       DateTime         @updatedAt @map("updatedAt")

  @@index([role])
  @@map("users")
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  action    String
  cost      Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CreditPurchase {
  id        String   @id @default(cuid())
  userId    String
  package   String
  credits   Int
  amount    Int
  status    String   @default("PAID")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Finance Module ──────────────────────────────────────────────────────────

enum FinancialAccountType {
  cash
  bank
  pix
  credit_card
}

enum FinancialTransactionType {
  income
  expense
}

enum FinancialTransactionStatus {
  pending
  paid
  canceled
}

/**
 * Conta/carteira financeira por unidade (caixa, banco, PIX, cartão etc.).
 */
model FinancialAccount {
  id        String               @id @default(cuid())
  storeId   String               @default("loja-1") @map("storeId")
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name      String               @map("name")
  type      FinancialAccountType @default(cash) @map("type")
  balance   Float                @default(0) @map("balance")
  active    Boolean              @default(true) @map("active")
  createdAt DateTime             @default(now()) @map("createdAt")
  updatedAt DateTime             @updatedAt @map("updatedAt")

  transactions FinancialTransaction[]

  @@index([storeId])
  @@index([storeId, active])
  @@map("financial_accounts")
}

/**
 * Categoria financeira por unidade (receita ou despesa).
 */
model FinancialCategory {
  id        String                   @id @default(cuid())
  storeId   String                   @default("loja-1") @map("storeId")
  store     Store                    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name      String                   @map("name")
  type      FinancialTransactionType @map("type")
  color     String                   @default("#6366f1") @map("color")
  icon      String                   @default("tag") @map("icon")
  createdAt DateTime                 @default(now()) @map("createdAt")

  transactions FinancialTransaction[]

  @@index([storeId])
  @@index([storeId, type])
  @@map("financial_categories")
}

/**
 * Transação financeira unificada (receita/despesa, contas a pagar/receber).
 */
model FinancialTransaction {
  id             String                     @id @default(cuid())
  storeId        String                     @default("loja-1") @map("storeId")
  store          Store                      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  accountId      String                     @map("accountId")
  account        FinancialAccount           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId     String?                    @map("categoryId")
  category       FinancialCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /**
   * Referência opcional a cliente (string desnormalizado; FK opcional).
   */
  clienteId      String?                    @map("clienteId")
  /**
   * Referência opcional a uma Venda.
   */
  vendaId        String?                    @map("vendaId")
  /**
   * Referência opcional a uma OrdemServico (id).
   */
  osId           String?                    @map("osId")
  type           FinancialTransactionType   @map("type")
  status         FinancialTransactionStatus @default(pending) @map("status")
  description    String                     @default("") @map("description")
  amount         Float                      @default(0) @map("amount")
  dueDate        DateTime                   @map("dueDate")
  paidAt         DateTime?                  @map("paidAt")
  /**
   * Competência contábil (mês/ano de referência).
   */
  competencyDate DateTime?                  @map("competencyDate")
  paymentMethod  String?                    @map("paymentMethod")
  notes          String?                    @map("notes") @db.Text
  createdById    String?                    @map("createdById")
  createdAt      DateTime                   @default(now()) @map("createdAt")
  updatedAt      DateTime                   @updatedAt @map("updatedAt")

  attachments FinancialAttachment[]

  @@index([storeId])
  @@index([storeId, type])
  @@index([storeId, status])
  @@index([storeId, dueDate])
  @@index([accountId])
  @@index([categoryId])
  @@index([osId])
  @@index([vendaId])
  @@map("financial_transactions")
}

/**
 * Anexo vinculado a uma transação financeira.
 */
model FinancialAttachment {
  id            String               @id @default(cuid())
  transactionId String               @map("transactionId")
  transaction   FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fileName      String               @map("fileName")
  fileUrl       String               @map("fileUrl")
  createdAt     DateTime             @default(now()) @map("createdAt")

  @@index([transactionId])
  @@map("financial_attachments")
}

// ─── Auditoria / Conciliação / Fechamento Financeiro ─────────────────────────

/**
 * Fechamento financeiro diário ou mensal.
 * Congela o estado do fluxo no momento do fechamento e permite reabertura controlada.
 */
model FechamentoFinanceiro {
  id              String    @id @default(cuid())
  storeId         String    @default("loja-1") @map("storeId")
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * "diario" | "mensal"
   */
  tipo            String    @default("diario") @map("tipo")
  /**
   * yyyy-mm-dd para diário; 1º dia do mês para mensal
   */
  dataReferencia  String    @map("dataReferencia")
  mes             Int       @map("mes")
  ano             Int       @map("ano")
  /**
   * "aberto" | "fechado" | "reaberto"
   */
  status          String    @default("fechado") @map("status")
  saldoSistema    Float     @default(0) @map("saldoSistema")
  saldoInformado  Float?    @map("saldoInformado")
  diferenca       Float     @default(0) @map("diferenca")
  observacao      String?   @map("observacao") @db.Text
  snapshotDRE     Json?     @map("snapshotDRE") @db.JsonB
  fechadoPor      String?   @map("fechadoPor")
  reabertoPor     String?   @map("reabertoPor")
  fechadoEm       DateTime? @map("fechadoEm")
  reabertoEm      DateTime? @map("reabertoEm")
  createdAt       DateTime  @default(now()) @map("createdAt")
  updatedAt       DateTime  @updatedAt @map("updatedAt")

  @@unique([storeId, tipo, dataReferencia], name: "fechamento_store_tipo_data")
  @@index([storeId])
  @@index([storeId, tipo])
  @@index([storeId, mes, ano])
  @@map("fechamentos_financeiros")
}

/**
 * Conciliação de saldo de carteira financeira (sistema vs. informado).
 */
model ConciliacaoFinanceira {
  id              String             @id @default(cuid())
  storeId         String             @default("loja-1") @map("storeId")
  store           Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  carteiraId      String             @map("carteiraId")
  carteira        CarteiraFinanceira @relation(fields: [carteiraId], references: [id], onDelete: Restrict)
  /**
   * yyyy-mm-dd data da conciliação
   */
  dataReferencia  String             @map("dataReferencia")
  saldoSistema    Float              @default(0) @map("saldoSistema")
  saldoInformado  Float              @default(0) @map("saldoInformado")
  diferenca       Float              @default(0) @map("diferenca")
  /**
   * "pendente" | "conciliado" | "divergente"
   */
  status          String             @default("pendente") @map("status")
  observacao      String?            @map("observacao") @db.Text
  conciliadoPor   String?            @map("conciliadoPor")
  conciliadoEm    DateTime?          @map("conciliadoEm")
  createdAt       DateTime           @default(now()) @map("createdAt")
  updatedAt       DateTime           @updatedAt @map("updatedAt")

  @@index([storeId])
  @@index([carteiraId])
  @@index([storeId, dataReferencia])
  @@index([storeId, status])
  @@map("conciliacoes_financeiras")
}

/**
 * Log imutável de auditoria de operações financeiras.
 * Nunca atualizar nem deletar — append-only.
 */
model AuditoriaFinanceira {
  id           String   @id @default(cuid())
  storeId      String   @default("loja-1") @map("storeId")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * "movimentacao" | "receber" | "pagar" | "carteira" | "dre" | "fechamento" | "conciliacao"
   */
  entidade     String   @map("entidade")
  entidadeId   String?  @map("entidadeId")
  /**
   * "criar" | "editar" | "excluir" | "liquidar" | "estornar" | "fechar" | "reabrir" | "conciliar"
   */
  acao         String   @map("acao")
  /**
   * Estado antes da operação (JSON snapshot)
   */
  antes        Json?    @map("antes") @db.JsonB
  /**
   * Estado depois da operação (JSON snapshot)
   */
  depois       Json?    @map("depois") @db.JsonB
  usuarioId    String?  @map("usuarioId")
  usuarioNome  String?  @map("usuarioNome")
  ip           String?  @map("ip")
  userAgent    String?  @map("userAgent")
  createdAt    DateTime @default(now()) @map("createdAt")

  @@index([storeId])
  @@index([storeId, entidade])
  @@index([storeId, entidadeId])
  @@index([storeId, createdAt])
  @@map("auditorias_financeiras")
}

// ─── PDV Enterprise — Sessões e Operações de Caixa ───────────────────────────

enum SessaoCaixaStatus {
  ABERTA
  FECHADA
}

/**
 * Sessão de caixa PDV: abertura → fechamento com saldo inicial/final.
 * Persiste no servidor para auditoria e dashboards sem remover o localStorage fast-path.
 */
model SessaoCaixa {
  id           String             @id @default(cuid())
  storeId      String             @map("storeId")
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  operador     String             @default("") @map("operador")
  saldoInicial Float              @default(0) @map("saldoInicial")
  saldoFinal   Float?             @map("saldoFinal")
  saldoContado Float?             @map("saldoContado")
  observacao   String             @default("") @map("observacao")
  status       SessaoCaixaStatus  @default(ABERTA) @map("status")
  abertaEm     DateTime           @default(now()) @map("abertaEm")
  fechadaEm    DateTime?          @map("fechadaEm")
  /** Snapshot de totais do dia (ledger) no momento do fechamento. */
  payload      Json?              @map("payload") @db.JsonB
  operacoes    CaixaOperacao[]
  devolucoes   DevolucaoVenda[]

  @@index([storeId, status])
  @@index([storeId, abertaEm])
  @@map("sessoes_caixa")
}

/**
 * Operações avulsas durante a sessão: sangria, suprimento, devolução.
 */
model CaixaOperacao {
  id       String      @id @default(cuid())
  sessaoId String      @map("sessaoId")
  sessao   SessaoCaixa @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  storeId  String      @map("storeId")
  /** "sangria" | "suprimento" | "devolucao" */
  tipo     String      @map("tipo")
  valor    Float       @default(0) @map("valor")
  motivo   String      @default("") @map("motivo")
  operador String      @default("") @map("operador")
  at       DateTime    @default(now()) @map("at")
  payload  Json?       @map("payload") @db.JsonB

  @@index([sessaoId])
  @@index([storeId, at])
  @@map("caixa_operacoes")
}

// ─── Omni Agent HUB — comandos auditáveis (Fase 1) ──────────────────────────

enum OmniAgentCommandStatus {
  PENDENTE
  AGUARDANDO_CONFIRMACAO
  EXECUTADO
  ERRO
}

/**
 * Comando interpretado pelo Omni Agent HUB (texto → intenção → execução controlada).
 */
model OmniAgentCommand {
  id               String                  @id @default(cuid())
  storeId          String                  @map("storeId")
  store            Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /** Canal de origem: texto_interno | whatsapp | voz */
  canal            String                  @default("texto_interno") @map("canal")
  comandoOriginal  String                  @map("comandoOriginal") @db.Text
  interpretacao    Json                    @map("interpretacao") @db.JsonB
  status           OmniAgentCommandStatus  @map("status")
  resultado        Json?                   @map("resultado") @db.JsonB
  executadoEm      DateTime?               @map("executadoEm")
  createdAt        DateTime                @default(now()) @map("createdAt")

  automationRuns OmniAgentAutomationRun[]

  @@index([storeId, createdAt])
  @@index([storeId, status])
  @@map("omni_agent_commands")
}

/**
 * Automações Omni Agent (gatilho de domínio → comando na Inbox, sem execução automática perigosa).
 */
model OmniAgentAutomation {
  id              String   @id @default(cuid())
  storeId         String   @map("storeId")
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name            String   @default("") @map("name")
  /** venda_finalizada | os_entregue | conta_receber_vencida */
  triggerKey      String   @map("triggerKey")
  enabled         Boolean  @default(false) @map("enabled")
  commandTemplate String   @map("commandTemplate") @db.Text
  priority        Int      @default(0) @map("priority")
  createdAt       DateTime @default(now()) @map("createdAt")
  updatedAt       DateTime @updatedAt @map("updatedAt")

  runs OmniAgentAutomationRun[]

  @@index([storeId, enabled])
  @@index([storeId, triggerKey])
  @@map("omni_agent_automations")
}

model OmniAgentAutomationRun {
  id             String   @id @default(cuid())
  automationId String   @map("automationId")
  automation   OmniAgentAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  storeId      String   @map("storeId")
  eventKey     String   @map("eventKey")
  entityId     String?  @map("entityId")
  comandoGerado String  @map("comandoGerado") @db.Text
  commandId    String?  @map("commandId")
  omniCommand  OmniAgentCommand? @relation(fields: [commandId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("createdAt")

  @@index([storeId, createdAt])
  @@index([automationId, createdAt])
  @@map("omni_agent_automation_runs")
}

// ─── NextAuth / Admin Auth ───────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  GERENTE
  OPERADOR
  CAIXA
  TECNICO
  VENDEDOR
}

/**
 * Vínculo N:N entre usuário admin e lojas com acesso explícito (Fase Auth Enterprise).
 * Se vazio para o usuário, usa-se `lojaId` primária ou regras legadas na aplicação.
 */
model AdminUserStore {
  id          String    @id @default(cuid())
  adminUserId String    @map("adminUserId")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  storeId     String    @map("storeId")
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("createdAt")

  @@unique([adminUserId, storeId])
  @@index([storeId])
  @@map("admin_user_stores")
}

/**
 * Usuários de acesso ao painel OmniGestão (email + senha). Separado do User PIN-based.
 */
model AdminUser {
  id        String   @id @default(cuid())
  name      String   @default("")
  email     String   @unique
  password  String
  role      UserRole @default(OPERADOR)
  lojaId    String?
  /** Conta ativa; inativos não autenticam no painel. */
  active    Boolean  @default(true) @map("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUserStores AdminUserStore[]

  // ─── Stripe / Billing ───────────────────────────────────────────────────────
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  /**
   * active | canceled | past_due | trialing | incomplete | unpaid
   */
  subscriptionStatus   String?
  /**
   * BRONZE | PRATA | OURO | DIAMANTE
   */
  planName             String?
  /**
   * monthly | yearly
   */
  billingInterval      String?
  creditsIA            Int       @default(0)
  creditsUsed          Int       @default(0)
  currentPeriodEnd     DateTime?

  @@map("admin_users")
}
