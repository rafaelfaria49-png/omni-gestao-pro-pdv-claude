generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoreProfile {
  ASSISTENCIA
  VARIEDADES
  SUPERMERCADO
}

enum SubscriptionPlan {
  BRONZE
  PRATA
  OURO
}

enum MarketingMediaJobKind {
  IMAGE
  VOICE
  VIDEO
  AVATAR
  REUNIAO
  AUTOMACAO
}

model Store {
  /**
   * Use ids estáveis: loja-1, loja-2, ...
   */
  id               String           @id
  name             String           @default("") @map("name")
  cnpj             String           @default("") @map("cnpj")
  phone            String           @default("") @map("phone")
  logoUrl          String           @default("") @map("logoUrl")
  /**
   * Endereço completo (rua/numero/bairro/cidade/uf/cep) como JSON.
   */
  address          Json?            @map("address") @db.JsonB
  profile          StoreProfile     @default(ASSISTENCIA) @map("profile")
  /**
   * Plano SaaS oficial por unidade (first-class).
   */
  subscriptionPlan SubscriptionPlan @default(BRONZE) @map("subscriptionPlan")
  createdAt        DateTime         @default(now()) @map("createdAt")
  updatedAt        DateTime         @updatedAt @map("updatedAt")

  clientes               Cliente[]
  produtos               Produto[]
  servicos               Servico[]
  ordensServico          OrdemServico[]
  contasReceber          ContaReceberTitulo[]
  contasPagar            ContaPagarTitulo[]
  movimentacoes          MovimentacaoFinanceira[]
  carteiras              CarteiraFinanceira[]
  fechamentos            FechamentoFinanceiro[]
  conciliacoes           ConciliacaoFinanceira[]
  auditorias             AuditoriaFinanceira[]
  fornecedores           Fornecedor[]
  financialAccounts      FinancialAccount[]
  financialCategories    FinancialCategory[]
  financialTransactions  FinancialTransaction[]
  vendas                 Venda[]
  categorias             CategoriaProduto[]
  categoriasCadastro     CategoriaCadastro[]
  marcasCadastro         MarcaCadastro[]
  tecnicos               Tecnico[]
  equipamentosModelos    EquipamentoModelo[]
  productMedia           ProductMedia[]
  marketplaceListings    MarketplaceListing[]
  settings               StoreSettings?
  iaConversations        IaConversation[]
  iaMessages             IaMessage[]
  marketingIaPosts       MarketingIaPost[]
  marketingPosts         MarketingPost[]
  marketingMediaJobs     MarketingMediaJob[]
  whatsappContacts       WhatsAppContact[]
  whatsappConversations  WhatsAppConversation[]
  whatsappMessages       WhatsAppMessage[]
  whatsappAutomations    WhatsAppAutomation[]
  whatsappQuickReplies   WhatsAppQuickReply[]
  whatsappEtiquetas      WhatsAppEtiqueta[]
  whatsappAiSetting      WhatsAppAiSetting?
  whatsappAutomationLogs WhatsAppAutomationLog[]
  sessoesCaixa           SessaoCaixa[]
  devolucoes             DevolucaoVenda[]
  garantiasOrdemServico  GarantiaOrdemServico[]
  adminUserStores        AdminUserStore[]
  omniAgentCommands      OmniAgentCommand[]
  omniAgentAutomations   OmniAgentAutomation[]
  marketplaceConnections   MarketplaceConnection[]
  marketplaceSyncLogs      MarketplaceSyncLog[]
  marketplaceProductLinks  MarketplaceProductLink[]

  @@index([profile])
  @@map("stores")
}

enum MarketplaceProvider {
  MERCADO_LIVRE @map("mercado_livre")
  SHOPEE        @map("shopee")
  AMAZON        @map("amazon")
  MAGALU        @map("magalu")
}

enum MarketplaceConnectionStatus {
  DISCONNECTED @map("disconnected")
  CONNECTED    @map("connected")
  ERROR        @map("error")
  SYNCING      @map("syncing")
}

/** Estado de publicação do vínculo produto ↔ canal (simulado na Fase 2). */
enum MarketplaceProductLinkStatus {
  NOT_PUBLISHED @map("not_published")
  PUBLISHED     @map("published")
  ERROR         @map("error")
}

/** Estado de sincronização do vínculo (simulado). */
enum MarketplaceProductSyncStatus {
  IDLE       @map("idle")
  PENDING    @map("pending")
  SYNCED     @map("synced")
  SYNC_ERROR @map("sync_error")
}

/**
 * Conta de marketplace por unidade (OAuth real na Fase 2+).
 */
model MarketplaceConnection {
  id              String                        @id @default(cuid())
  storeId         String                        @map("storeId")
  store           Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider        MarketplaceProvider           @map("provider")
  accountName     String                        @map("accountName")
  status          MarketplaceConnectionStatus   @default(DISCONNECTED) @map("status")
  /** Placeholder até criptografia/KMS — não expor na API pública. */
  accessToken     String                        @default("") @map("accessToken")
  refreshToken    String                        @default("") @map("refreshToken")
  metadata        Json?                         @map("metadata") @db.JsonB
  lastSyncAt      DateTime?                     @map("lastSyncAt")
  lastSyncMessage String                        @default("") @map("lastSyncMessage")
  createdAt       DateTime                      @default(now()) @map("createdAt")
  updatedAt       DateTime                      @updatedAt @map("updatedAt")

  syncLogs     MarketplaceSyncLog[]
  productLinks MarketplaceProductLink[]

  @@index([storeId])
  @@index([storeId, provider])
  @@map("marketplace_connections")
}

/**
 * Histórico de sincronização simulada / futura sync real.
 * Opcionalmente amarrado a produto e vínculo (Fase 3 — filtros na UI).
 */
model MarketplaceSyncLog {
  id             String                  @id @default(cuid())
  storeId        String                  @map("storeId")
  store          Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  connectionId   String                  @map("connectionId")
  connection     MarketplaceConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  produtoId      String?                 @map("produtoId")
  produto        Produto?                @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  productLinkId  String?                 @map("productLinkId")
  productLink    MarketplaceProductLink? @relation(fields: [productLinkId], references: [id], onDelete: SetNull)
  message        String                  @map("message")
  createdAt      DateTime                @default(now()) @map("createdAt")

  @@index([storeId])
  @@index([connectionId, createdAt])
  @@index([storeId, produtoId, createdAt])
  @@index([productLinkId, createdAt])
  @@map("marketplace_sync_logs")
}

/**
 * Vínculo leve produto interno ↔ conta de marketplace (Fase 2 — sem OAuth/publicação real).
 */
model MarketplaceProductLink {
  id           String                       @id @default(cuid())
  storeId      String                       @map("storeId")
  store        Store                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  produtoId    String                       @map("produtoId")
  produto      Produto                      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  connectionId String                       @map("connectionId")
  connection   MarketplaceConnection        @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider     MarketplaceProvider          @map("provider")
  externalId   String?                      @map("externalId")
  status       MarketplaceProductLinkStatus @default(NOT_PUBLISHED) @map("status")
  syncStatus   MarketplaceProductSyncStatus @default(IDLE) @map("syncStatus")
  price        Float                        @default(0) @map("price")
  stock        Int                          @default(0) @map("stock")
  publishedAt  DateTime?                    @map("publishedAt")
  metadata     Json?                        @map("metadata") @db.JsonB
  createdAt    DateTime                     @default(now()) @map("createdAt")
  updatedAt    DateTime                     @updatedAt @map("updatedAt")

  syncLogs MarketplaceSyncLog[]

  @@unique([connectionId, produtoId], name: "marketplace_product_link_connection_produto")
  @@index([storeId])
  @@index([storeId, produtoId])
  @@map("marketplace_product_links")
}

/**
 * Contato WhatsApp por unidade (Cloud API / Evolution — id externo opcional).
 */
model WhatsAppContact {
  id            String   @id @default(cuid())
  storeId       String   @map("storeId")
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /**
   * Identificador oficial WhatsApp quando disponível (ex.: número @c.us ou wa_id).
   */
  waExternalId  String   @default("") @map("waExternalId")
  /**
   * Somente dígitos com DDI (normalizado).
   */
  phoneDigits   String   @map("phoneDigits")
  displayName   String   @default("") @map("displayName")
  profilePicUrl String   @default("") @map("profilePicUrl")
  metadata      Json?    @map("metadata") @db.JsonB
  createdAt     DateTime @default(now()) @map("createdAt")
  updatedAt     DateTime @updatedAt @map("updatedAt")

  conversations WhatsAppConversation[]

  @@unique([storeId, phoneDigits], name: "whatsapp_contact_store_phone")
  @@index([storeId])
  @@map("whatsapp_contacts")
}

model WhatsAppConversation {
  id                 String          @id @default(cuid())
  storeId            String          @map("storeId")
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId          String          @map("contactId")
  contact            WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /**
   * Vínculo opcional com cliente cadastrado (match por telefone normalizado).
   */
  clienteId          String?         @map("clienteId")
  cliente            Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  externalThreadId   String          @default("") @map("externalThreadId")
  status             String          @default("open") @map("status")
  assignedToUserId   String          @default("") @map("assignedToUserId")
  humanMode          Boolean         @default(false) @map("humanMode")
  lastMessagePreview String          @default("") @map("lastMessagePreview") @db.Text
  lastMessageAt      DateTime?       @map("lastMessageAt")
  unreadCount        Int             @default(0) @map("unreadCount")
  metadata           Json?           @map("metadata") @db.JsonB
  createdAt          DateTime        @default(now()) @map("createdAt")
  updatedAt          DateTime        @updatedAt @map("updatedAt")

  messages  WhatsAppMessage[]
  etiquetas WhatsAppConversacaoEtiqueta[]

  @@index([storeId, lastMessageAt])
  @@index([contactId])
  @@index([clienteId])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id                String               @id @default(cuid())
  storeId           String               @map("storeId")
  store             Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversationId    String               @map("conversationId")
  conversation      WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction         String               @map("direction")
  body              String               @map("body") @db.Text
  messageType       String               @default("text") @map("messageType")
  externalMessageId String               @default("") @map("externalMessageId")
  payload           Json?                @map("payload") @db.JsonB
  createdAt         DateTime             @default(now()) @map("createdAt")

  @@index([storeId, createdAt])
  @@index([conversationId, createdAt])
  @@map("whatsapp_messages")
}

model WhatsAppAutomation {
  id          String   @id @default(cuid())
  storeId     String   @map("storeId")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String   @map("name")
  triggerType String   @default("keyword") @map("triggerType")
  enabled     Boolean  @default(true) @map("enabled")
  priority    Int      @default(0) @map("priority")
  conditions  Json?    @map("conditions") @db.JsonB
  actions     Json?    @map("actions") @db.JsonB
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  logs WhatsAppAutomationLog[]

  @@index([storeId, enabled])
  @@map("whatsapp_automations")
}

model WhatsAppQuickReply {
  id        String   @id @default(cuid())
  storeId   String   @map("storeId")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shortcut  String   @map("shortcut")
  title     String   @map("title")
  body      String   @map("body") @db.Text
  category  String   @default("") @map("category")
  sortOrder Int      @default(0) @map("sortOrder")
  ativo     Boolean  @default(true) @map("ativo")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  @@unique([storeId, shortcut], name: "whatsapp_quick_reply_store_shortcut")
  @@index([storeId])
  @@map("whatsapp_quick_replies")
}

model WhatsAppEtiqueta {
  id           String   @id @default(cuid())
  storeId      String   @map("storeId")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  nome         String   @map("nome")
  cor          String   @default("#10b981") @map("cor")
  ativo        Boolean  @default(true) @map("ativo")
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  conversacoes WhatsAppConversacaoEtiqueta[]

  @@unique([storeId, nome], name: "wa_etiqueta_store_nome")
  @@index([storeId])
  @@map("whatsapp_etiquetas")
}

model WhatsAppConversacaoEtiqueta {
  id             String               @id @default(cuid())
  conversationId String               @map("conversationId")
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  etiquetaId     String               @map("etiquetaId")
  etiqueta       WhatsAppEtiqueta     @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now()) @map("createdAt")

  @@unique([conversationId, etiquetaId])
  @@index([conversationId])
  @@index([etiquetaId])
  @@map("whatsapp_conversa_etiquetas")
}

/**
 * Uma linha de configuração de IA por loja (sugestões simuladas no hub).
 */
model WhatsAppAiSetting {
  id                 String   @id @default(cuid())
  storeId            String   @unique @map("storeId")
  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tone               String   @default("consultivo") @map("tone")
  systemPrompt       String   @default("") @map("systemPrompt") @db.Text
  suggestionsEnabled Boolean  @default(true) @map("suggestionsEnabled")
  maxContextMessages Int      @default(12) @map("maxContextMessages")
  metadata           Json?    @map("metadata") @db.JsonB
  updatedAt          DateTime @updatedAt @map("updatedAt")

  @@map("whatsapp_ai_settings")
}

model WhatsAppAutomationLog {
  id           String              @id @default(cuid())
  storeId      String              @map("storeId")
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  automationId String?             @map("automationId")
  automation   WhatsAppAutomation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  level        String              @default("info") @map("level")
  action       String              @map("action")
  message      String              @default("") @map("message") @db.Text
  payload      Json?               @map("payload") @db.JsonB
  createdAt    DateTime            @default(now()) @map("createdAt")

  @@index([storeId, createdAt])
  @@index([action])
  @@map("whatsapp_automation_logs")
}

/**
 * Posts do Marketing IA Hub (conteúdo editorial por unidade).
 * Status/canal em string validada na API (pt-BR).
 */
model MarketingPost {
  id          String    @id @default(cuid())
  storeId     String    @map("storeId")
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  titulo      String    @map("titulo")
  /** instagram | facebook | whatsapp | google | geral */
  canal       String    @map("canal")
  /** rascunho | agendado | publicado | erro */
  status      String    @default("rascunho") @map("status")
  conteudo    String    @default("") @map("conteudo") @db.Text
  legenda     String    @default("") @map("legenda") @db.Text
  hashtags    String    @default("") @map("hashtags")
  cta         String    @default("") @map("cta")
  imagemUrl   String    @default("") @map("imagemUrl")
  scheduledAt DateTime? @map("scheduledAt")
  publishedAt DateTime? @map("publishedAt")
  metadata    Json?     @map("metadata") @db.JsonB
  createdAt   DateTime  @default(now()) @map("createdAt")
  updatedAt   DateTime  @updatedAt @map("updatedAt")

  @@index([storeId, status])
  @@index([storeId, scheduledAt])
  @@index([storeId, createdAt])
  @@map("marketing_posts")
}

/**
 * Legenda e agendamentos do Estúdio Marketing IA (IA Mestre), por unidade.
 */
model MarketingIaPost {
  id           String    @id @default(cuid())
  storeId      String    @map("storeId")
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  caption      String    @map("caption") @db.Text
  productName  String    @default("") @map("productName")
  tone         String    @default("") @map("tone")
  /**
   * GENERATED (rascunho/gerado) | SCHEDULED (agendado)
   */
  status       String    @default("GENERATED") @map("status")
  scheduledFor DateTime? @map("scheduledFor")
  createdAt    DateTime  @default(now()) @map("createdAt")
  updatedAt    DateTime  @updatedAt @map("updatedAt")

  @@index([storeId, createdAt])
  @@map("marketing_ia_posts")
}

model StoreSettings {
  id                    String   @id @default(cuid())
  storeId               String   @unique @map("storeId")
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /**
   * Contatos por unidade (não herdar da RafaCell).
   */
  contactEmail          String   @default("") @map("contactEmail")
  contactWhatsapp       String   @default("") @map("contactWhatsapp")
  contactWhatsappDono   String   @default("") @map("contactWhatsappDono")
  /**
   * Rodapé do cupom (mensagem por CNPJ/unidade).
   */
  receiptFooter         String   @default("") @map("receiptFooter") @db.Text
  /**
   * Config de impressão (host/porta/modelo) por unidade.
   */
  printerConfig         Json?    @map("printerConfig") @db.JsonB
  /**
   * Taxas de cartão e regras financeiras por unidade.
   */
  cardFees              Json?    @map("cardFees") @db.JsonB
  /**
   * Créditos do Estúdio de Mídia (locução / vídeo IA) por unidade.
   */
  marketingMediaCredits Int      @default(50) @map("marketingMediaCredits")
  /**
   * Mascote 3D fixo da loja (consistência de personagem).
   */
  mascotCharacterSeed   String   @default("") @map("mascotCharacterSeed")
  mascotPromptBase      String   @default("") @map("mascotPromptBase") @db.Text
  updatedAt             DateTime @updatedAt @map("updatedAt")

  @@map("store_settings")
}

/**
 * Histórico de jobs de mídia (locução/vídeo) para auditoria e evolução futura.
 */
model MarketingMediaJob {
  id                  String                 @id @default(cuid())
  storeId             String                 @map("storeId")
  store               Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /**
   * Kind legado (String). Preferir `kindV2`.
   */
  kind                String                 @map("kind")
  /**
   * Kind novo (enum) para padronização/validação.
   */
  kindV2              MarketingMediaJobKind? @map("kindV2")
  /**
   * Seed do personagem (Mascote Studio / consistência).
   */
  characterSeed       String?                @map("characterSeed")
  /**
   * Prompt base fixo do personagem.
   */
  promptBase          String?                @map("promptBase") @db.Text
  /**
   * Status por rede social (multidifusão).
   */
  socialNetworkStatus Json?                  @map("socialNetworkStatus") @db.JsonB
  meta                Json?                  @map("meta") @db.JsonB
  creditsAfter        Int?                   @map("creditsAfter")
  createdAt           DateTime               @default(now()) @map("createdAt")

  @@index([storeId, createdAt])
  @@map("marketing_media_jobs")
}

model IaConversation {
  id      String @id @default(cuid())
  storeId String @map("storeId")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  /**
   * Nome opcional (ex.: "Campanhas Abril", "OS/Orçamentos").
   */
  title             String  @default("") @map("title")
  /**
   * Modelo selecionado (ex.: "gpt-4o", "claude-3.5", "auto").
   */
  model             String  @default("auto") @map("model")
  /**
   * Se true, aplicar identidade/brand voice da loja.
   */
  brandVoiceEnabled Boolean @default(true) @map("brandVoiceEnabled")

  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  messages IaMessage[]

  @@index([storeId, updatedAt])
  @@map("ia_conversations")
}

model IaMessage {
  id      String @id @default(cuid())
  storeId String @map("storeId")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  conversationId String         @map("conversationId")
  conversation   IaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String @map("role") // "user" | "assistant" | "system"
  content String @map("content") @db.Text
  /**
   * Payload auxiliar opcional (tokens, tool calls, etc.)
   */
  meta    Json?  @map("meta") @db.JsonB

  createdAt DateTime @default(now()) @map("createdAt")

  @@index([storeId, createdAt])
  @@index([conversationId, createdAt])
  @@map("ia_messages")
}

model Cliente {
  id             String    @id @default(cuid())
  storeId        String    @default("loja-1") @map("storeId")
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  name           String    @map("name")
  /**
   * PF/PJ para Cadastros HUB e OS futuro.
   */
  kind           String    @default("PF") @map("kind")
  /**
   * CPF/CNPJ (normalizado ou com máscara).
   */
  document       String    @default("") @map("document")
  phone          String?   @map("phone")
  email          String?   @map("email")
  /**
   * Ex.: "São Paulo/SP" (compatível com UI atual).
   */
  city           String    @default("") @map("city")
  /**
   * Tags livres (UI atual usa string[]).
   */
  tags           Json?     @map("tags") @db.JsonB
  active         Boolean   @default(true) @map("active")
  /**
   * Campos auxiliares para UI (opcionais).
   */
  totalSpent     Float     @default(0) @map("totalSpent")
  lastPurchaseAt DateTime? @map("lastPurchaseAt")
  createdAt      DateTime  @default(now()) @map("createdAt")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updatedAt")

  ordensServico         OrdemServico[]
  vendas                Venda[]
  whatsappConversations WhatsAppConversation[]

  @@index([storeId])
  @@map("clientes_importados")
}

enum StatusOrdemServico {
  Aberto
  EmAnalise
  Pronto
  Entregue
}

model OrdemServico {
  id           String             @id @default(cuid())
  storeId      String             @default("loja-1") @map("storeId")
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Número exibido / chave de deduplicação na importação de planilhas.
   */
  numero       String?            @map("numero")
  /**
   * Snapshot JSON legado (importador universal / backups).
   */
  payload      Json?              @map("payload") @db.JsonB
  clienteId    String?            @map("clienteId")
  cliente      Cliente?           @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  equipamento  String             @default("") @map("equipamento")
  defeito      String             @default("") @map("defeito") @db.Text
  laudoTecnico String?            @map("laudoTecnico") @db.Text
  /**
   * Valor de mão de obra / serviço sem peças do estoque.
   */
  valorBase    Float              @default(0) @map("valorBase")
  valorTotal   Float              @default(0) @map("valorTotal")
  status       StatusOrdemServico @default(Aberto) @map("status")
  createdAt    DateTime           @default(now()) @map("createdAt")
  updatedAt    DateTime           @default(now()) @updatedAt @map("updatedAt")

  itens                  OrdemServicoItem[]
  garantiasOperacionais  GarantiaOrdemServico[]

  @@index([storeId])
  @@index([clienteId])
  @@index([numero])
  @@index([status])
  @@map("ordens_servico")
}

/// Garantia operacional persistida (complementa o snapshot JSON em `payload.garantia`).
model GarantiaOrdemServico {
  id             String       @id @default(cuid())
  storeId        String       @map("storeId")
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ordemServicoId String       @map("ordemServicoId")
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  prazoDias      Int          @map("prazoDias")
  cobertura      String       @default("") @map("cobertura") @db.Text
  observacoes    String       @default("") @map("observacoes") @db.Text
  dataInicio     DateTime     @map("dataInicio")
  dataFim        DateTime     @map("dataFim")
  /// ativa | expirada | cancelada
  status         String       @default("ativa") @map("status")
  createdAt      DateTime     @default(now()) @map("createdAt")

  @@index([storeId])
  @@index([ordemServicoId])
  @@index([status])
  @@map("garantia_ordem_servico")
}

model OrdemServicoItem {
  id             String       @id @default(cuid())
  ordemServicoId String       @map("ordemServicoId")
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  /**
   * Peça vinculada ao catálogo (estoque). Nulo quando `tipo = "servico"` (mão de obra sem SKU).
   */
  produtoId String?  @map("produtoId")
  produto   Produto? @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  /** peca | servico */
  tipo       String @default("peca") @map("tipo")
  /** Rótulo persistido (nome da peça ou descrição do serviço). */
  descricao  String @default("") @map("descricao")
  quantidade Int    @map("quantidade")
  /**
   * Preço unitário no momento da baixa (snapshot).
   */
  precoUnitario Float @map("precoUnitario")
  observacao    String @default("") @map("observacao") @db.Text

  @@index([ordemServicoId])
  @@index([produtoId])
  @@map("ordem_servico_item")
}

model Produto {
  id           String   @id @default(cuid())
  storeId      String   @default("loja-1") @map("storeId")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  /**
   * Código de barras / SKU (pode se repetir em lojas diferentes).
   */
  sku          String?  @map("sku")
  /**
   * Código de barras (EAN/GTIN) — leitura no PDV Alta Performance.
   */
  barcode      String?  @map("barcode")
  name         String   @map("name")
  brand        String   @default("") @map("brand")
  supplierName String   @default("") @map("supplierName")
  stock        Int      @default(0) @map("stock")
  /**
   * Custo unitário (planilhas/backup): coluna `price_cost` no Supabase.
   */
  precoCusto   Float    @default(0) @map("price_cost")
  price        Float    @default(0) @map("price")
  category     String?  @map("category")
  warrantyDays Int      @default(0) @map("warrantyDays")
  status       String   @default("Ativo") @map("status")
  active       Boolean  @default(true) @map("active")
  /** Extensível (Fase IA: foto, voz, WhatsApp, pipeline) — não substituir colunas core. */
  metadata     Json?    @map("metadata") @db.JsonB
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @default(now()) @updatedAt @map("updatedAt")

  ordemServicoItens         OrdemServicoItem[]
  media                     ProductMedia[]
  marketplaceListings     MarketplaceListing[]
  marketplaceProductLinks MarketplaceProductLink[]
  marketplaceSyncLogs     MarketplaceSyncLog[]

  @@unique([storeId, sku], name: "storeId_sku")
  @@unique([storeId, barcode], name: "storeId_barcode")
  @@index([storeId])
  @@map("estoque_produtos")
}

model Tecnico {
