{
  "name": "omni-gestao-pro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack -p 3000 -H 0.0.0.0",
    "dev:clean": "npx kill-port 3000 && npm run dev",
    "dev:https": "next dev --webpack --experimental-https",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:node": "node scripts/run-prisma-db-push.mjs",
    "db:migrate": "prisma migrate dev",
    "db:smoke": "node --env-file=.env scripts/prisma-smoke.mjs",
    "db:migrate-loja": "node --env-file=.env scripts/migrate-loja-ids.mjs",
    "db:check-rls": "node --env-file=.env scripts/check-rls-tables.mjs",
    "db:migrate-legacy-financeiro": "node --env-file=.env scripts/migrate-legacy-financeiro.mjs"
  },
