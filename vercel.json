{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",

  "headers": [
    {
      "source": "/api/webhooks/whatsapp",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/api/debug/webhook-echo",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],

  "crons": []
}
